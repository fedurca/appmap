{
  "description": "Regex patterns matched against a process comm/cmdline/exe to derive a logical application name and optional layer-7 protocol. First match wins; patterns are case-insensitive.",
  "patterns": [
    {"pattern": "nginx", "application": "nginx", "l7": "http"},
    {"pattern": "\\bhttpd\\b|apache2", "application": "apache-httpd", "l7": "http"},
    {"pattern": "haproxy", "application": "haproxy", "l7": "http"},
    {"pattern": "envoy", "application": "envoy", "l7": "http"},
    {"pattern": "traefik", "application": "traefik", "l7": "http"},
    {"pattern": "mysqld|mariadbd", "application": "mysql", "l7": "mysql"},
    {"pattern": "postgres", "application": "postgresql", "l7": "postgres"},
    {"pattern": "redis-server", "application": "redis", "l7": "redis"},
    {"pattern": "memcached", "application": "memcached", "l7": "memcached"},
    {"pattern": "mongod", "application": "mongodb", "l7": "mongodb"},
    {"pattern": "java.*elasticsearch|org\\.elasticsearch", "application": "elasticsearch", "l7": "http"},
    {"pattern": "java.*kafka|kafka\\.Kafka", "application": "kafka", "l7": "kafka"},
    {"pattern": "java.*zookeeper|QuorumPeerMain", "application": "zookeeper", "l7": "zookeeper"},
    {"pattern": "rabbitmq|beam.smp.*rabbit", "application": "rabbitmq", "l7": "amqp"},
    {"pattern": "dockerd", "application": "docker", "l7": null},
    {"pattern": "containerd", "application": "containerd", "l7": null},
    {"pattern": "kubelet", "application": "kubelet", "l7": "https"},
    {"pattern": "kube-apiserver", "application": "kube-apiserver", "l7": "https"},
    {"pattern": "etcd", "application": "etcd", "l7": "etcd"},
    {"pattern": "sshd", "application": "openssh", "l7": "ssh"},
    {"pattern": "named|bind9|unbound|dnsmasq|coredns", "application": "dns-server", "l7": "dns"},
    {"pattern": "chronyd|ntpd", "application": "ntp", "l7": "ntp"},
    {"pattern": "postfix|master.*postfix|smtpd", "application": "postfix", "l7": "smtp"},
    {"pattern": "dovecot", "application": "dovecot", "l7": "imap"},
    {"pattern": "zabbix_agent", "application": "zabbix-agent", "l7": "zabbix"},
    {"pattern": "zabbix_server", "application": "zabbix-server", "l7": "zabbix"},
    {"pattern": "prometheus", "application": "prometheus", "l7": "http"},
    {"pattern": "node_exporter", "application": "node-exporter", "l7": "http"},
    {"pattern": "grafana", "application": "grafana", "l7": "http"},
    {"pattern": "gunicorn|uwsgi", "application": "python-wsgi-app", "l7": "http"},
    {"pattern": "(?:^|/)node(?:js)?[0-9.]*(?=$|\\s)|(?:^|/|\\s)np[mx](?=$|\\s)", "application": "nodejs-app", "l7": "http"},
    {"pattern": "php-fpm", "application": "php-fpm", "l7": "fastcgi"}
  ]
}
