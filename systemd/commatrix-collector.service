[Unit]
Description=Commatrix network flow collector (nf_conntrack)
Documentation=https://example.com/commatrix
After=network-online.target
Wants=network-online.target

[Service]
Type=simple
# Must run as root to read /proc/net/nf_conntrack and /proc/<pid>/fd, and to
# toggle the nf_conntrack sysctls.
User=root
# Best-effort load of the connection tracking module (ignored if unavailable).
# commatrix itself reads the sysctls' original values, enables them for the run
# and restores them on stop, so we deliberately do NOT force them here (that
# would hide the true pre-commatrix baseline from the restore logic).
ExecStartPre=-/sbin/modprobe nf_conntrack
ExecStart=/usr/bin/commatrix collect --config /etc/commatrix/commatrix.conf
# Belt-and-braces restore in case the main process was killed (SIGKILL/OOM)
# and never ran its own shutdown restore. No-op when already restored.
ExecStopPost=/usr/bin/commatrix restore-sysctls --config /etc/commatrix/commatrix.conf
Restart=on-failure
RestartSec=5

# --- Resource safety: never hurt the host --------------------------------
# Lowest scheduling priority so real workloads always win.
Nice=19
CPUSchedulingPolicy=idle
IOSchedulingClass=idle
CPUWeight=10
IOWeight=10
# Hard CPU ceiling. This defaults to 10% of ONE core; the installer replaces
# it via a drop-in with 10% of TOTAL compute (10% * nproc). The in-process
# governor also self-throttles to 10% of total compute.
CPUQuota=10%
# Memory ceiling (advisory; matches memory_max_mb in the config).
MemoryMax=128M
MemoryHigh=96M
TasksMax=64

# --- Light sandboxing (process still needs broad read access to /proc) ----
NoNewPrivileges=true
ProtectHome=true
ProtectControlGroups=true
ProtectKernelTunables=false
RuntimeDirectory=commatrix
StateDirectory=commatrix

[Install]
WantedBy=multi-user.target
